---
const principles = [
  {
    title: "Fixed scope, fixed price",
    body: "Briefs become a concrete spec and a written quote within 24 hours. We only kick off when we both agree on what 'done' looks like.",
  },
  {
    title: "Written-first, async by default",
    body: "Daily written updates on active projects. Short Loom walkthroughs replace long calls when something needs visual context. UK time, full overlap with European business hours.",
  },
  {
    title: "Production-shaped code",
    body: "Typed Python, tests where they matter, Docker setup, README, .env.example, runbook. Your team should be able to pick it up cold and ship.",
  },
  {
    title: "Your code, your repo",
    body: "MIT-style handover. No vendor lock-in, no managed services I control, no monthly maintenance fee unless you ask for one.",
  },
];
---

<section id="how" class="border-b border-ink-200 bg-ink-950 text-ink-50">
  <div class="container-narrow py-20 sm:py-24">
    <div class="mb-12 max-w-3xl">
      <h2 class="text-2xl font-bold tracking-tight text-white sm:text-3xl">
        How I work
      </h2>
      <p class="mt-3 text-lg text-ink-300 sm:text-xl">
        The four things that mostly decide whether a project goes well.
      </p>
    </div>
    <div class="grid gap-6 sm:grid-cols-2">
      {
        principles.map((p) => (
          <div class="rounded-lg border border-ink-700 bg-ink-900/60 p-6">
            <h3 class="text-lg font-semibold text-white">{p.title}</h3>
            <p class="mt-3 text-ink-300">{p.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
